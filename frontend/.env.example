# ============================================================
# Save The City - Frontend Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Your deployed SaveTheCity contract address
# You get this after running: npm run deploy:ritual
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# WalletConnect Project ID
# Get one free at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Ritual Chain RPC URL
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
