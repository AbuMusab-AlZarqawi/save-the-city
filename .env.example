# ============================================================
# Save The City - Hardhat Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Your wallet private key (the one with testnet RITUAL tokens)
# Get this from MetaMask: Account > ... > Account Details > Export Private Key
# NEVER share this or commit it to GitHub
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Ritual Chain RPC URL (default works for testnet)
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
